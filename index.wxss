/* 全局样式 - 淡蓝色+圆润风格 */
page {
  background-color: #f5f9fc;
  width: 375px;
  height: 812px;
  margin: 0 auto;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 状态栏 - 淡蓝色基调 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  height: 44rpx;
  background-color: #e8f4f8;
  font-size: 24rpx;
  color: #4a90e2;
  border-bottom: 1rpx solid #d1e7f0;
  border-radius: 0 0 16rpx 16rpx;
}

/* 功能按钮区 - 圆润+淡蓝 */
.func-btn-wrap {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  margin: 16rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.05);
}

.onekey-btn {
  flex: 2;
  background: linear-gradient(135deg, #4a90e2 0%, #6ba5e8 100%);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 8rpx rgba(74, 144, 226, 0.15);
}

.clear-btn {
  flex: 1;
  background-color: #fff;
  color: #4a90e2;
  border: 1rpx solid #d1e7f0;
  border-radius: 20rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
}

/* 三餐随机抽选区 - 淡蓝色+圆润 */
.meal-random-section {
  background-color: #fff;
  padding: 24rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #d1e7f0;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.08);
}

.meal-item {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #e8f4f8;
}

.meal-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.meal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d5a8c;
}

.meal-tag {
  font-size: 20rpx;
  color: #8cb4e0;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.food-random-box {
  height: 88rpx;
  line-height: 88rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #d1e7f0;
  border-radius: 16rpx;
  overflow: hidden;
  text-align: center;
  background-color: #f8fbfe;
}

.random-food {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d5a8c;
  transition: all 0.1s;
}

.rolling {
  transform: translateY(-100%);
  animation: roll 0.1s infinite;
}

@keyframes roll {
  0% { transform: translateY(0); }
  100% { transform: translateY(-88rpx); }
}

.random-btn {
  background: linear-gradient(135deg, #4a90e2 0%, #6ba5e8 100%);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  width: 100%;
  font-weight: 500;
  box-shadow: 0 4rpx 8rpx rgba(74, 144, 226, 0.15);
}

.random-btn:disabled {
  background: #c9d8e6;
  color: #fff;
  opacity: 0.8;
  box-shadow: none;
}

/* 标签筛选 - 圆润+淡蓝 */
.tag-scroll {
  background-color: #fff;
  padding: 16rpx 0;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #d1e7f0;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.05);
}

.tag-scroll-wrap {
  white-space: nowrap;
  padding: 0 20rpx;
}

.tag-item {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin-right: 16rpx;
  background-color: #f8fbfe;
  border: 1rpx solid #d1e7f0;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #6ba5e8;
}

.tag-item.active {
  background: linear-gradient(135deg, #4a90e2 0%, #6ba5e8 100%);
  color: #fff;
  border-color: #4a90e2;
}

/* 食物列表 - 淡蓝+圆润（新增操作按钮样式） */
.food-list {
  padding: 0 20rpx;
}

.food-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #d1e7f0;
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 226, 0.05);
}

.food-info {
  width: 100%;
}

.food-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d5a8c;
}

.food-meal-tag {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #4a90e2 0%, #6ba5e8 100%);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.food-date {
  font-size: 24rpx;
  color: #8cb4e0;
  margin-bottom: 12rpx;
}

.tag-chip {
  display: inline-block;
  padding: 4rpx 16rpx;
  background-color: #f8fbfe;
  border: 1rpx solid #d1e7f0;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #6ba5e8;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 新增：食物操作按钮 */
.food-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.edit-btn {
  flex: 1;
  background-color: #f8fbfe;
  color: #4a90e2;
  border: 1rpx solid #d1e7f0;
  border-radius: 16rpx;
  padding: 8rpx 0;
  font-size: 24rpx;
}

.delete-btn {
  flex: 1;
  background-color: #fff0f0;
  color: #f56c6c;
  border: 1rpx solid #fde2e2;
  border-radius: 16rpx;
  padding: 8rpx 0;
  font-size: 24rpx;
}

/* 悬浮添加按钮 - 淡蓝+圆润 */
.float-add-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #4a90e2 0%, #6ba5e8 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.2);
}

/* 弹窗样式 - 淡蓝+圆润 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  z-index: 999;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  z-index: 1000;
  max-height: 80vh;
  overflow-y: auto;
  border-top: 2rpx solid #e8f4f8;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e8f4f8;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d5a8c;
}

.modal-close {
  font-size: 32rpx;
  color: #8cb4e0;
}

.modal-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
  color: #2d5a8c;
}

/* 三餐分类选择 */
.meal-type-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.meal-type-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6ba5e8;
}

.food-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #d1e7f0;
  border-radius: 16rpx;
  font-size: 26rpx;
  background-color: #f8fbfe;
}

.tag-check-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-check-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6ba5e8;
}

.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recommend-item {
  padding: 8rpx 20rpx;
  background-color: #f8fbfe;
  border: 1rpx solid #d1e7f0;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #6ba5e8;
}

.modal-submit {
  width: 100%;
  background: linear-gradient(135deg, #4a90e2 0%, #6ba5e8 100%);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 8rpx rgba(74, 144, 226, 0.15);
}

/* 新增：删除确认弹窗样式 */
.delete-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1001;
  width: 80%;
}

.delete-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
}

.delete-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d5a8c;
  display: block;
  margin-bottom: 16rpx;
}

.delete-desc {
  font-size: 24rpx;
  color: #8cb4e0;
  display: block;
  margin-bottom: 24rpx;
}

.delete-btns {
  display: flex;
  gap: 16rpx;
}

.cancel-btn {
  flex: 1;
  background-color: #f8fbfe;
  color: #6ba5e8;
  border: 1rpx solid #d1e7f0;
  border-radius: 16rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
}

.confirm-delete-btn {
  flex: 1;
  background-color: #f56c6c;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
}